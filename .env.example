# Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# JWT — REQUIRED: generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be a random secret of at least 32 bytes. The server will refuse to start without this.
JWT_SECRET="replace-with-a-random-32+-byte-secret"
JWT_EXPIRES_IN="7d"

# CSRF protection — set to your production URL (e.g. https://app.example.com)
# Used by server/middleware/csrf.ts to validate the Origin header on mutation requests.
# If unset, the middleware derives the allowed origin from the Host header (https://<host>).
# NUXT_PUBLIC_SITE_URL="https://app.example.com"
